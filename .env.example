# Environment variables for SCRAM project
# Copy this file to .env and fill in your API keys

# ============================================================================
# REQUIRED API KEYS
# ============================================================================

# US Census Bureau API Key (REQUIRED for trade data collection)
# Get your free key at: https://api.census.gov/data/key_signup.html
# Used by: USCensusCollector
# Data: Import/export data for semiconductors, equipment, and materials
US_CENSUS_API_KEY=your_census_api_key_here


# ============================================================================
# OPTIONAL API KEYS
# ============================================================================

# FRED API Key (OPTIONAL - for ISM PMI and other economic indicators)
# Get your free key at: https://fredaccount.stlouisfed.org/apikeys
# Used by: MacroIndicatorCollector
# Data: ISM Manufacturing PMI, new orders, supplier deliveries
# Note: If not provided, collector will use mock data or skip PMI collection
FRED_API_KEY=your_fred_api_key_here


# ============================================================================
# PROXY SETTINGS (if needed)
# ============================================================================
# Optional: Proxy settings if needed
# HTTP_PROXY=http://proxy.example.com:8080
# HTTPS_PROXY=https://proxy.example.com:8080

# Database credentials (for future use)
# DB_HOST=localhost
# DB_PORT=5432
# DB_NAME=scram_db
# DB_USER=scram_user
# DB_PASSWORD=your_password_here
